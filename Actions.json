            "keywords":["what is","where","who","how"],
            "parameters":{
                "question":"this is what the user is trying to ask ai"
            },
            "example_input": "how many people live on the moon",
            "example_output": {
                "action": "ask_ai",
                "question": "how many people live on the moon "
            }
        }
    ],

    "response_format": {
        "description": "Format for AI to return actions",
        "with_parameters": {
            "action": "action_name",
            "parameter_name": "extracted_value"
        },
        "without_parameters": {
            "action": "action_name"
        },
        "no_action": {
            "action": "none"
        }
